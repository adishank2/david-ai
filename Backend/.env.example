# Environment Configuration for David AI Assistant

# Ollama Configuration
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=phi3

# Audio Configuration
SAMPLE_RATE=16000
RECORDING_DURATION=3

# Voice Configuration (Edge TTS)
# Available voices: https://speech.microsoft.com/portal/voicegallery
TTS_VOICE=en-IN-NeerjaNeural

# Wake Word Detection
# Set to 'true' to enable wake word activation (requires Porcupine access key)
WAKE_WORD_ENABLED=false
WAKE_WORD_SENSITIVITY=0.5
# Get free access key from https://picovoice.ai/
PORCUPINE_ACCESS_KEY=

# Continuous Listening
CONTINUOUS_MODE=true
VAD_AGGRESSIVENESS=3
SILENCE_DURATION=1.5

# Context & Memory
CONTEXT_ENABLED=true
CONTEXT_HISTORY_SIZE=10

# Web Search
WEB_SEARCH_ENABLED=true

# Plugins
PLUGINS_ENABLED=true
PLUGINS_DIR=plugins

